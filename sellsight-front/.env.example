# OAuth providers (public client IDs — safe to expose in frontend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_SLACK_CLIENT_ID=your-slack-client-id
NEXT_PUBLIC_OAUTH_SLACK_CLIENT_ID=your-slack-client-id

# Stripe (publishable key — safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Backend API base URL (used by client-side code)
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1

# Internal backend URL for Next.js server-side rewrites (not exposed to browser)
# In production on Vercel: set to your Digital Ocean backend URL
BACKEND_INTERNAL_URL=http://localhost:8081
