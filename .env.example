# ---- Postgres ----
POSTGRES_USER=sellsight
POSTGRES_PASSWORD=sellsight
POSTGRES_DB=sellsight_db

# ---- JWT ----
# Generate a fresh base64-encoded 256-bit key in production.
JWT_SECRET=replace-me-with-a-256-bit-base64-secret
JWT_EXPIRATION=86400000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Internal URL used by Next.js rewrites to proxy /api/* calls to the backend
BACKEND_INTERNAL_URL=http://localhost:8081

# ---- App ----
# Used to build verification / password-reset links.
APP_BASE_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins (prod: your Vercel domain)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Kafka ----
# Host-side bootstrap (maps to the EXTERNAL listener exposed on :29092).
# The backend-in-docker override sets this to kafka:9092 via docker-compose.

KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Email (Resend) ----
# Leave blank in local dev — the LoggingEmailAdapter logs outbound emails instead.
RESEND_API_KEY=

# ---- OAuth ----
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_SLACK_CLIENT_ID=
OAUTH_SLACK_CLIENT_SECRET=
OAUTH_SLACK_REDIRECT_URI=http://localhost:3000/oauth/callback


# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_...
# From Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
